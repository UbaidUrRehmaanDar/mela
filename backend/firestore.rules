rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isModerator() {
      return isAuthenticated() && getUserData().role == 'moderator';
    }
    
    function isModeratorFor(university) {
      return isModerator() && university in getUserData().moderatorFor;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users Collection
    match /users/{userId} {
      // Anyone can read user profiles (for displaying organizer info)
      allow read: if true;
      
      // Users can create their own profile
      allow create: if isAuthenticated() 
                    && request.auth.uid == userId
                    && request.resource.data.role == 'student'; // Default role
      
      // Users can update their own profile (except role and moderatorFor)
      allow update: if isOwner(userId)
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.moderatorFor == resource.data.moderatorFor;
      
      // Only admins can update roles and moderator assignments
      allow update: if isAdmin();
      
      // Only admins can delete users
      allow delete: if isAdmin();
    }
    
    // Events Collection (Approved Events)
    match /events/{eventId} {
      // Everyone can read approved events
      allow read: if true;
      
      // Only moderators can create events (via Cloud Function after approval)
      allow create: if isModerator();
      
      // Moderators can update events from their university
      allow update: if isModeratorFor(resource.data.university);
      
      // Only admins can delete events
      allow delete: if isAdmin();
    }
    
    // Submissions Collection (Pending Events)
    match /submissions/{submissionId} {
      // Organizers can read only their own submissions
      allow read: if isOwner(resource.data.organizerId);
      
      // Moderators can read submissions for their universities
      allow read: if isModerator() && resource.data.university in getUserData().moderatorFor;
      
      // Authenticated users can create submissions
      allow create: if isAuthenticated()
                    && request.resource.data.organizerId == request.auth.uid
                    && request.resource.data.organizerEmail == request.auth.token.email
                    && request.resource.data.status == 'pending';
      
      // Organizers can update their own pending submissions
      allow update: if isOwner(resource.data.organizerId)
                    && resource.data.status == 'pending'
                    && request.resource.data.status == 'pending';
      
      // Moderators can update submissions (for rejection)
      allow update: if isModeratorFor(resource.data.university);
      
      // Moderators can delete submissions (after approval, moved to events)
      allow delete: if isModeratorFor(resource.data.university);
      
      // Organizers can delete their own rejected submissions
      allow delete: if isOwner(resource.data.organizerId) 
                    && resource.data.status == 'rejected';
    }
    
    // Saved Events Collection
    match /savedEvents/{savedEventId} {
      // Users can only read their own saved events
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Users can create saved events for themselves
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid;
      
      // Users can update their own saved events
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Users can delete their own saved events
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Alternative: Saved Events as Subcollection
    match /users/{userId}/savedEvents/{eventId} {
      allow read, write: if isOwner(userId);
    }
    
    // Moderators Collection (Optional)
    match /moderators/{moderatorId} {
      // Anyone can read to verify moderator status
      allow read: if true;
      
      // Only admins can create, update, or delete moderators
      allow write: if isAdmin();
    }
  }
}
